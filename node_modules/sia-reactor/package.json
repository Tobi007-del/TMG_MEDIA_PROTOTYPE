{
  "name": "sia-reactor",
  "version": "0.0.4",
  "description": "The Programmable Data DOM. A high-performance State Intent Architecture (S.I.A.) Engine with zero-allocation loops, event propagation, and structural sharing.",
  "author": "Oketade Oluwatobiloba <tobioketade007@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobi007-del/sia-reactor.git"
  },
  "bugs": {
    "url": "https://github.com/tobi007-del/sia-reactor/issues"
  },
  "homepage": "https://github.com/tobi007-del/sia-reactor#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.global.js",
  "unpkg": "./dist/index.global.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs",
      "default": "./dist/utils.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/utils.ts src/types.ts --format cjs,esm,iife --global-name sia --dts --clean --minify",
    "dev": "tsup src/index.ts src/utils.ts src/types.ts --format cjs,esm,iife --global-name sia --dts --watch --minify"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "reactor",
    "sia",
    "state",
    "intent",
    "architecture",
    "engine",
    "event",
    "propagation",
    "state-management",
    "reactive",
    "proxy",
    "events",
    "data-dom",
    "structural-sharing",
    "performance"
  ],
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
